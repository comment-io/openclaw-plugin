{
  "name": "@comment-io/openclaw-plugin",
  "version": "1.3.63",
  "description": "Official Comment.io plugin for OpenClaw — @mention notifications and agent API guidance",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./setup": "./dist/setup-entry.js"
  },
  "files": [
    "index.ts",
    "setup-entry.ts",
    "channel.ts",
    "channel.setup.ts",
    "channel.runtime.ts",
    "src/",
    "openclaw.plugin.json",
    "dist/"
  ],
  "devDependencies": {
    "openclaw": ">=2026.4.1"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "comment-io",
      "label": "Comment.io",
      "selectionLabel": "Comment.io",
      "detailLabel": "comment.io",
      "docsPath": "/channels/comment-io",
      "docsLabel": "comment-io",
      "blurb": "Collaborative markdown editor — @mention the agent in any doc.",
      "aliases": [
        "cdocs",
        "commentdocs"
      ],
      "order": 80
    },
    "install": {
      "npmSpec": "@comment-io/openclaw-plugin",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.1"
    },
    "build": {
      "openclawVersion": "2026.4.5"
    },
    "compat": {
      "pluginApi": ">=2026.4.1"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
